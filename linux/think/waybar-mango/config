{
	"layer": "top", // on top of windows
	"position": "bottom",
	//"modules-left": ["custom/lock", "clock#time", "clock#calendar"],
	"modules-left": ["network", "battery", "backlight", "pulseaudio", "tray"],
    "modules-center": ["dwl/tags"],
	//"modules-right": ["tray", "network", "battery", "backlight", "pulseaudio"],
	"modules-right": ["clock#calendar", "clock#time", "custom/lock"],
    "width": 900,
    "margin-bottom": 6,

	"custom/lock": {
		"format": "",
		//"on-click": "mmsg -q",
		"on-click": "~/.local/share/quickshell-lockscreen/lock.sh",
		"tooltip": true,
		"tooltip-format": "logout",
	},
	
	"pulseaudio": {
		"tooltip": false,
		"scroll-step": 2,
		"format": "{icon} {volume}%",
		"format-muted": " {volume}%",
		"on-click":"pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"format-icons": {
			"default": ["", "", ""]
		},
		"smooth-scrolling-threshold": 1.0,
	},

	"hyprland/workspaces": {
		"format": "{icon}",
		"on-scroll-up": "hyprctl dispatch workspace m+1",
		"on-scroll-down": "hyprctl dispatch workspace m-1",
		"format-icons": {
			"7": "",
			"8": "",
			"9": "",
		},
	},

    "dwl/tags": {
		"num-tags": 9,
		"on-scroll-up": "mmsg -d viewtoright,0",
		"on-scroll-down": "mmsg -d viewtoleft,0",
		"tag-labels": ["1", "2", "3", "4", "5", "6", "7", "8", "9"],
    },
    "river/tags": {
		"num-tags": 8,
		"max-length": 1,
        "on-scroll-up": "riverctl increment-focused-tags 8",
        "on-scroll-down": "riverctl decrement-focused-tags 8",
		"tag-labels": ["1", "2", "3", "4", "5", "6", "7", "8"],
    },

	"network": {
		//"interface": "wlp3s0",
		"format-wifi": "{icon}",
		"format-icons": ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"],
		"format-disconnected": "󰤮",
		"format-ethernet": "",
		"tooltip": true,
		"tooltip-format-wifi": "{essid} - {ipaddr}",
		"tooltip-disconnected": "{ifname}",
		"on-click": "rfkill unblock wlan",
	},

	"backlight": {
		"tooltip": false,
		"format": " {}%",
        "on-scroll-up": "brightnessctl s 5%+",
		"on-scroll-down": "brightnessctl s 5%-",
		"smooth-scrolling-threshold": 2.0,
	},

    "battery": {
		"bat": "BAT1",
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["", "", "", "", ""],
		"interval": "5",
    },

	"tray":{
		"spacing": 10
	},

    "clock#time": {
        "format": " {:%H:%M}",
		"interval":1,
		"tooltip": false,
    },

    "clock#calendar": {
        "format": " {:%a %d/%m}",
		"tooltip-format": "<tt>{calendar}</tt>",
		"smooth-scrolling-threshold": 3,
		"calendar": {
			"mode"          : "month",
			"on-scroll"     : 1,
			"format": {
				"months":     "<span color='#ffead3'><b>{}</b></span>",
				"days":       "<span color='#ecc6d9'><b>{}</b></span>",
				"weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
				"weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
				"today":      "<span color='#ff6699'><b><u>{}</u></b></span>",
			},
		},
        "actions": {
			"on-click": "shift_up",
			"on-click-middle": "shift_reset",
			"on-click-right": "shift_down",
			"on-scroll-up": "shift_down",
			"on-scroll-down": "shift_up",
		},
    },
}
