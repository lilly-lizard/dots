[{
	"name": "left-mon",
	"layer": "top",
	"output": "DP-1",
	"position": "bottom",
	//"modules-left": ["dwl/tags#primary"],
	"modules-left": [
		"dwl/tags#primary",
		"custom/r-arr-1","custom/r-arr-2","custom/r-arr-3","custom/r-arr-4"
	],
	"modules-center": [
		"custom/l-arr-4","custom/l-arr-3","custom/l-arr-2","custom/l-arr-1",
		"mpris",
		"custom/r-arr-1","custom/r-arr-2","custom/r-arr-3","custom/r-arr-4"
	],
	"modules-right": [
		"custom/l-arr-4","custom/l-arr-3","custom/l-arr-2","custom/l-arr-1",
		"tray", "network", "pulseaudio", "custom/ddc_brightness_primary", "clock#calendar", "clock#time", "custom/power"
	],

	"dwl/tags#primary": {
		"num-tags": 8,
		"on-scroll-up": "mmsg -d viewtoright,0",
		"on-scroll-down": "mmsg -d viewtoleft,0",
		"tag-labels": ["1", "2", "3", "4", "5", "6", "ΎΞ░", "≤░╣δ"],
	},
	"ext/workspaces#primary": {
		"on-scroll-up": "mmsg -d viewtoright,0",
		"on-scroll-down": "mmsg -d viewtoleft,0",
		"persistent-workspaces": {
			"1": [],
			"2": [],
			"3": [],
			"4": [],
			"5": [],
			"6": [],
			"7": [],
			"8": [],
		},
		"format-icons": ["1", "2", "3", "4", "5", "6", "ΎΞ░", "≤░╣δ"],
	},

	"mpris": {
		"format": "{status_icon} {dynamic}",
		"status-icons": {
			"playing": "έΨ╢",
			"paused": "έΠ╕",
		},
		"max-length": 70,
		"on-click": "mpris2controller PlayPause",
		//"tooltip-format": "{player}",
	},
	
	"network": {
		//"interface": "enp8s0",
		"format-wifi": "{icon} {essid}",
		"format-icons": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
		"format-ethernet": "Ό╜Ε",
		"format-disconnected": "≤░ΙΓ",
		"tooltip": true,
		"tooltip-format": "{ifname} - {ipaddr}",
		"tooltip-disconnected": "{ifname}",
		"on-click": "rfkill unblock wlan",
	},

	"pulseaudio": {
		"tooltip": false,
		"scroll-step": 2,
		"format": "{icon} {volume}%",
		"format-muted": "Όυν {volume}%",
		"on-click":"pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"format-icons": {
			"default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
		},
		"smooth-scrolling-threshold": 1.0,
	},

	"river/window": {
		"max-length": 50,
		"tooltip": true,
	},

	"tray":{
		//"icon-size":18,
		"spacing": 10,
		"tooltip": false,
	},

	"custom/ddc_brightness_primary": {
		"format": "{icon} {percentage}%",
		"format-icons": ["≤▒σΟ", "≤▒σΠ", "≤▒σΡ", "≤▒σΣ", "≤▒σΤ", "≤▒σΥ", "≤▒σΦ", "≤▒σΧ", "≤▒σΨ", "≤░δρ"],
		"exec": "~/.config/waybar/waybar-ddc-module-primary.sh",
		"return-type": "json",
		"on-scroll-up":   "echo '+'   > /tmp/waybar-ddc-module-rx-primary",
		"on-scroll-down": "echo '-'   > /tmp/waybar-ddc-module-rx-primary",
		"on-click":       "echo 'max' > /tmp/waybar-ddc-module-rx-primary",
		"on-click-right": "echo 'min' > /tmp/waybar-ddc-module-rx-primary",
		"tooltip": false,
	},

	"clock#calendar": {
		"format": "Ό╝╖ {:%a %d/%m/%y}"
	},

	"clock#time": {
		"format": "≤░ξΦ {:%H:%M}",
		"interval":1,
	},

	"custom/power": {
		"format": "≤░Ρξ",
		"on-click": "systemctl suspend",
		"tooltip": true,
		"tooltip-format": "suspend",
	},

	"custom/r-arr-1": {
		"format": "ΌΓ░",
		"tooltip": false
	},
	"custom/r-arr-2": {
		"format": "ΌΓ░",
		"tooltip": false
	},
	"custom/r-arr-3": {
		"format": "ΌΓ░",
		"tooltip": false
	},
	"custom/r-arr-4": {
		"format": "ΌΓ░",
		"tooltip": false
	},
	"custom/l-arr-1": {
		"format": "ΌΓ▓",
		"tooltip": false
	},
	"custom/l-arr-2": {
		"format": "ΌΓ▓",
		"tooltip": false
	},
	"custom/l-arr-3": {
		"format": "ΌΓ▓",
		"tooltip": false
	},
	"custom/l-arr-4": {
		"format": "ΌΓ▓",
		"tooltip": false
	},
},
